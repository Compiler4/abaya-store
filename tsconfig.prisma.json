{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "esModuleInterop": true,
    "strict": true,

    /* ✅ Prevent casing issues (VERY IMPORTANT for deployment) */
    "forceConsistentCasingInFileNames": true,

    /* ✅ Speeds up builds (safe for most projects) */
    "skipLibCheck": true,

    /* ✅ Better DX */
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* Optional but good */
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": true
  },

  "include": ["prisma/**/*.ts"],

  "exclude": ["node_modules"]
}